# ---------------------------------------------------------------------------
# Copy this file to .env and fill in real values before running in production.
# ---------------------------------------------------------------------------

ENVIRONMENT=development
DEBUG=true

# Security — generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=CHANGE_ME_GENERATE_A_LONG_RANDOM_STRING
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
DATABASE_URL=postgresql+psycopg2://sentiment:sentiment@db:5432/sentiment_platform

# Redis
REDIS_URL=redis://redis:6379/0
CACHE_TTL_SECONDS=3600

# Rate limiting
RATE_LIMIT_PER_MINUTE=60

# Device for model inference: -1 = CPU, 0 = first GPU
DEVICE=-1

# ---------------------------------------------------------------------------
# Optional: real-time data connectors. Leave blank to use mock data sources.
# ---------------------------------------------------------------------------
TWITTER_BEARER_TOKEN=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
YOUTUBE_API_KEY=
NEWS_RSS_FEEDS=https://feeds.bbci.co.uk/news/rss.xml

# ---------------------------------------------------------------------------
# Optional: notification integrations for automated reports.
# ---------------------------------------------------------------------------
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
REPORT_EMAIL_TO=
